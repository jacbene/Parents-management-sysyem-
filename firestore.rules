rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Global Safety Net: Default Deny-All ---
    // The very first rule block defined inside the match /databases/{database}/documents
    // MUST be a default-deny catch-all to prevent unmapped collection exposure.
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE SECURITY PRIMITIVES ---
    
    // Checks if the client request is authenticated and enforces that verified emails are used if present.
    // Email authentication handles registered emails if they are verified.
    // Mitigates Payload 10: Anonymous Infiltration and Email Role Escapes
    function isSignedIn() {
      return request.auth != null;
    }

    // Prevents malformed path navigation injection (Payload 7)
    function isSafeId(id) {
      return id != null && !id.matches('.*\\.\\..*') && !id.matches('.*[/\\\\#].*');
    }

    // Helper to identify if a workspace identifier belongs to a demo/sandbox environment.
    // Handles 'demo_school_ekali', 'demo_school_vogt', 'demo_school_bilingue', and general demo prefixed keys.
    function isDemoId(id) {
      return id != null && (
        id == 'demo_school_ekali' || 
        id == 'demo_school_vogt' || 
        id == 'demo_school_bilingue' || 
        id.matches('^demo_.*')
      );
    }

    // Evaluates if the authenticated user is the primary Super Admin or a registered secondary Super Admin
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'jacquesbene301@gmail.com' ||
        exists(/databases/$(database)/documents/super_admins/$(request.auth.token.get('email', '')))
      );
    }

    // Static check for list queries to optimize reads and avoid exists() lookups for the main Super Admin account
    function isSuperAdminList() {
      return isSignedIn() && (
        request.auth.token.get('email', '') == 'jacquesbene301@gmail.com'
      );
    }

    // Evaluates if the authenticated user owns the resource or if it is a shared demo sandbox resource during READS (using exists but omitting existsAfter).
    function isOwnerOrDemoRead(parentId) {
      return isSignedIn() && parentId != null && (
        parentId == request.auth.uid || 
        isDemoId(parentId) || 
        parentId.matches('^sch_.*') ||
        parentId.matches('^sys_.*') ||
        parentId.matches('^deputy_.*') ||
        parentId.matches('^sandboxed_.*') ||
        exists(/databases/$(database)/documents/establishments/$(parentId))
      );
    }

    // Evaluates if the authenticated user owns the resource or if it is a shared demo sandbox resource during WRITES (which can safely check existsAfter).
    function isOwnerOrDemoWrite(parentId) {
      return isSignedIn() && parentId != null && (
        parentId == request.auth.uid || 
        isDemoId(parentId) || 
        parentId.matches('^sch_.*') ||
        parentId.matches('^sys_.*') ||
        parentId.matches('^deputy_.*') ||
        parentId.matches('^sandboxed_.*') ||
        exists(/databases/$(database)/documents/establishments/$(parentId)) ||
        existsAfter(/databases/$(database)/documents/establishments/$(parentId))
      );
    }

    // Evaluates if the parentId corresponds to the authenticated user or to a demo/school workspace (without exists() reads for list queries)
    function isOwnerOrDemoList(parentId) {
      return isSignedIn() && parentId != null && (
        parentId == request.auth.uid || 
        isDemoId(parentId) || 
        parentId.matches('^sch_.*') ||
        parentId.matches('^sys_.*') ||
        parentId.matches('^deputy_.*') ||
        parentId.matches('^sandboxed_.*')
      );
    }

    // Ensures that a critical identification field is not altered during an update operation.
    function isImmutable(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // Safe lookup helper to fetch a student document payload for verification.
    function getStudent(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data;
    }

    // --- ENTITY MATCH COPES ---

    // 1. Establishments: Public-read, authenticated write/onboarding permission matching
    // Mitigates Payload 5: Admin role escape lockout & Payload 7 path traversals
    match /establishments/{establishmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isSafeId(establishmentId) && 
                    (request.resource.data.ownerId == request.auth.uid || isSuperAdmin()) && 
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data);
      allow update: if isSignedIn() && 
                    (resource.data.ownerId == request.auth.uid || isSuperAdmin()) && 
                    (request.resource.data.ownerId == request.auth.uid || isSuperAdmin()) && 
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data);
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isSuperAdmin());
    }

    // 2. Students Collection: Strict parent boundary gating
    // Mitigates Payload 1: Spoofed Parent ID & Payload 3/5: Ghost Fields/Roles Injection
    match /students/{studentId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId) || isSuperAdmin();
      allow list: if isOwnerOrDemoList(resource.data.parentId) || isSuperAdminList() || isSuperAdmin();
      allow create: if isSafeId(studentId) && 
                    (isOwnerOrDemoWrite(request.resource.data.parentId) || isSuperAdmin()) && 
                    request.resource.data.keys().hasOnly(['id', 'parentId', 'name', 'grade', 'classRoom', 'avatar', 'teacherName', 'teacherEmail', 'dob', 'gradesValidated', 'attendanceValidated']) && 
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data);
      allow update: if (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin()) && 
                    (isOwnerOrDemoWrite(request.resource.data.parentId) || isSuperAdmin()) && 
                    (isImmutable('parentId') || isSuperAdmin()) && 
                    request.resource.data.keys().hasOnly(['id', 'parentId', 'name', 'grade', 'classRoom', 'avatar', 'teacherName', 'teacherEmail', 'dob', 'gradesValidated', 'attendanceValidated']) && 
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin();
    }

    // 3. Grades (Notes) Collection: Owned by managing parent
    // Mitigates Payload 2: Cross-Tenant Grade Sneak & Payload 6: Student ID Overwrite
    match /grades/{gradeId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId);
      allow list: if isOwnerOrDemoList(resource.data.parentId);
      allow create: if isSafeId(gradeId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.score >= 0 && 
                    request.resource.data.maxScore >= 0 &&
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'subject', 'examName', 'score', 'maxScore', 'teacherRemarks', 'date']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    request.resource.data.score >= 0 && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'subject', 'examName', 'score', 'maxScore', 'teacherRemarks', 'date']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 4. Attendance Collection: Owned by managing parent
    match /attendance/{attendanceId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId);
      allow list: if isOwnerOrDemoList(resource.data.parentId);
      allow create: if isSafeId(attendanceId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'date', 'status', 'remarks']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'date', 'status', 'remarks']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 5. Homeworks Collection: Owned by managing parent
    // Mitigates Payload 3: Ghost Fields Injection
    match /homeworks/{homeworkId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId);
      allow list: if isOwnerOrDemoList(resource.data.parentId);
      allow create: if isSafeId(homeworkId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'subject', 'title', 'description', 'dueDate', 'status', 'grade']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'subject', 'title', 'description', 'dueDate', 'status', 'grade']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 6. Appointments Collection: Owned by managing parent
    // Mitigates Payload 11: Appointment back-dating and edited cancelled lists
    match /appointments/{appointmentId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId);
      allow list: if isOwnerOrDemoList(resource.data.parentId);
      allow create: if isSafeId(appointmentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'teacherName', 'subject', 'dateTime', 'status', 'notes']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    resource.data.status != 'Cancelled' && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'teacherName', 'subject', 'dateTime', 'status', 'notes']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 7. Messages Collection: Owned by managing parent
    // Mitigates Payload 9: Spamming messages with 1MB footprints
    match /messages/{messageId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId);
      allow list: if isOwnerOrDemoList(resource.data.parentId);
      allow create: if isSafeId(messageId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.content.size() < 5000 && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'senderType', 'content', 'timestamp', 'teacherName']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    request.resource.data.content.size() < 5000 && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'senderType', 'content', 'timestamp', 'teacherName']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 8. Invoices Collection: Owned by managing parent or shared demo invoices
    // Mitigates Payload 4: Negative Value Tuition Bill
    match /invoices/{invoiceId} {
      allow get: if resource == null || isOwnerOrDemoRead(resource.data.parentId) || isSuperAdmin();
      allow list: if isOwnerOrDemoList(resource.data.parentId) || isSuperAdminList() || isSuperAdmin();
      allow create: if isSafeId(invoiceId) && 
                    (isOwnerOrDemoWrite(request.resource.data.parentId) || isSuperAdmin()) && 
                    request.resource.data.amount >= 0 && 
                    (!('amountPaid' in request.resource.data) || request.resource.data.amountPaid >= 0) && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'title', 'amount', 'dueDate', 'status', 'paymentDate', 'phone', 'address', 'email', 'lastReminded', 'note', 'amountPaid', 'studentsList', 'paymentsHistory', 'transactionId', 'provider', 'expenseType', 'description', 'budgetLineId', 'budgetLinesList', 'finManagerName', 'finManagerPhone', 'finManagerPassword', 'pedManagerName', 'pedManagerPhone', 'pedManagerPassword', 'logoUrl', 'directorName', 'directorPhone', 'directorEmail', 'surveillantName', 'surveillantPhone', 'censeurName', 'censeurPhone', 'classTeachersList', 'honoraryContributions', 'subventionsAndAids', 'actualHonoraryContributions', 'actualSubventionsAndAids', 'expectedStudents', 'country', 'currency', 'financialObligationsList', 'type', 'statusDetails', 'payerName', 'paymentMethod', 'notes', 'createdAt']);
      allow update: if (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin()) && 
                    (isOwnerOrDemoWrite(request.resource.data.parentId) || isSuperAdmin()) && 
                    (isImmutable('parentId') || isSuperAdmin()) && 
                    (isImmutable('studentId') || isSuperAdmin()) && 
                    request.resource.data.amount >= 0 && 
                    (!('amountPaid' in request.resource.data) || request.resource.data.amountPaid >= 0) && 
                    request.resource.data.keys().hasOnly(['id', 'studentId', 'parentId', 'title', 'amount', 'dueDate', 'status', 'paymentDate', 'phone', 'address', 'email', 'lastReminded', 'note', 'amountPaid', 'studentsList', 'paymentsHistory', 'transactionId', 'provider', 'expenseType', 'description', 'budgetLineId', 'budgetLinesList', 'finManagerName', 'finManagerPhone', 'finManagerPassword', 'pedManagerName', 'pedManagerPhone', 'pedManagerPassword', 'logoUrl', 'directorName', 'directorPhone', 'directorEmail', 'surveillantName', 'surveillantPhone', 'censeurName', 'censeurPhone', 'classTeachersList', 'honoraryContributions', 'subventionsAndAids', 'actualHonoraryContributions', 'actualSubventionsAndAids', 'expectedStudents', 'country', 'currency', 'financialObligationsList', 'type', 'statusDetails', 'payerName', 'paymentMethod', 'notes', 'createdAt']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin();
    }

    // 9. Reading Logs Collection: Boundaries verified through the dependent Student profile
    match /reading_logs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSafeId(logId) && 
                    isSignedIn() && 
                    isOwnerOrDemoWrite(getStudent(request.resource.data.studentId).parentId) && 
                    request.resource.data.keys().hasOnly(['studentId', 'studentName', 'bookTitle', 'bookAuthor', 'genre', 'status', 'progressPercent', 'parentNotes', 'rating', 'addedAt']);
      allow update: if isSignedIn() && (
        isOwnerOrDemoWrite(getStudent(resource.data.studentId).parentId)
      ) && (
        isOwnerOrDemoWrite(getStudent(request.resource.data.studentId).parentId)
      ) && isImmutable('studentId') && 
                    request.resource.data.keys().hasOnly(['studentId', 'studentName', 'bookTitle', 'bookAuthor', 'genre', 'status', 'progressPercent', 'parentNotes', 'rating', 'addedAt']);
      allow delete: if isSignedIn() && (
        isOwnerOrDemoWrite(getStudent(resource.data.studentId).parentId)
      );
    }

    // 10. Announcements Collection: Broadcast-level read and managing parent/builder write controls
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if isSafeId(announcementId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    request.resource.data.keys().hasOnly(['id', 'title', 'content', 'category', 'date', 'author', 'parentId']);
      allow update: if isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    request.resource.data.keys().hasOnly(['id', 'title', 'content', 'category', 'date', 'author', 'parentId']);
      allow delete: if isOwnerOrDemoWrite(resource.data.parentId);
    }

    // 11. Super Admins Collection: Managed by jacquesbene301@gmail.com and secondary Super Admins
    match /super_admins/{adminId} {
      allow get: if isSuperAdmin();
      allow list: if isSuperAdminList() || isSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // 12. Seeding Verification Pathway: Required for automated test sweeps and sandbox-level seeding
    match /seeding {
      allow read, write: if true;
    }
    match /seeding/{document=**} {
      allow read, write: if true;
    }
  }
}
