rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // 1. CATCH-ALL DENY - DOIT ÊTRE EN PREMIER
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 2. SEEDING - UNIQUEMENT APRÈS LE CATCH-ALL
    // ==========================================
    match /seeding/{document=**} {
      allow read, write: if true;
    }

    // ==========================================
    // 3. FONCTIONS UTILITAIRES DE SÉCURITÉ
    // ==========================================
    
    // Vérifie l'authentification de l'utilisateur
    function isSignedIn() {
      return request.auth != null;
    }

    // Valide les identifiants pour prévenir les injections de chemin
    function isSafeId(id) {
      return id != null && id.size() > 0 && id.size() < 128 && 
             id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Vérifie si un identifiant appartient à un environnement de démonstration
    function isDemoId(id) {
      return id != null && (
        id == 'demo_school_ekali' ||
        id == 'demo_school_vogt' ||
        id == 'demo_school_bilingue' ||
        id == 'sandboxed_guest_user_ekali' ||
        id == 'sandboxed_guest_user_vogt' ||
        id == 'sandboxed_guest_user_bilingue'
      );
    }

    // Vérifie si l'utilisateur est un Super Admin
    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.uid == "sys_admin_jacques" ||
        ('email' in request.auth.token && (
          request.auth.token.email.lower() == "jacquesbene301@gmail.com" ||
          request.auth.token.email.lower() == "adjoint@pasma.sys" ||
          exists(/databases/$(database)/documents/super_admins/$(request.auth.token.email.lower()))
        ))
      );
    }

    // Vérifie les droits en lecture pour les ressources démo ou possédées
    function isOwnerOrDemoRead(parentId) {
      return isDemoId(parentId) || 
             (isSignedIn() && (
               parentId == request.auth.uid || 
               exists(/databases/$(database)/documents/establishments/$(parentId))
             ));
    }

    // Vérifie les droits en écriture pour les ressources démo ou possédées
    function isOwnerOrDemoWrite(parentId) {
      return isDemoId(parentId) || 
             (isSignedIn() && (
               parentId == request.auth.uid || 
               (exists(/databases/$(database)/documents/establishments/$(parentId)) && 
                get(/databases/$(database)/documents/establishments/$(parentId)).data.ownerId == request.auth.uid)
             ));
    }

    // Vérifie les droits en listage pour les ressources démo ou possédées
    function isOwnerOrDemoList(parentId) {
      return isDemoId(parentId) || 
             (isSignedIn() && (
               parentId == request.auth.uid || 
               (parentId != request.auth.uid && exists(/databases/$(database)/documents/establishments/$(parentId)))
             ));
    }

    // Vérifie qu'un champ n'est pas modifié lors d'une mise à jour
    function isImmutable(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    // Valide les champs d'un document
    function validateFields(data, required, allowed) {
      return data.keys().hasOnly(allowed) && required.all(key => key in data);
    }

    // Récupère un étudiant en toute sécurité
    function getStudent(studentId) {
      return get(/databases/$(database)/documents/students/$(studentId)).data;
    }

    // Vérifie que les champs numériques sont valides
    function isValidNumber(field) {
      return field is int || field is float;
    }

    // ==========================================
    // 4. ÉTABLISSEMENTS
    // ==========================================
    match /establishments/{establishmentId} {
      allow read: if true;
      
      allow create: if isSignedIn() && isSafeId(establishmentId) && 
                    request.resource.data.ownerId == request.auth.uid && 
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data) &&
                    request.resource.data.size() < 1000;
      
      allow update: if isSignedIn() && 
                    resource.data.ownerId == request.auth.uid && 
                    request.resource.data.ownerId == request.auth.uid &&
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data) &&
                    request.resource.data.size() < 1000;
      
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ==========================================
    // 5. ÉTUDIANTS
    // ==========================================
    match /students/{studentId} {
      allow get: if isSignedIn() && resource != null && 
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(studentId) && 
                    (isSuperAdmin() || isOwnerOrDemoWrite(request.resource.data.parentId)) &&
                    validateFields(request.resource.data,
                      ['id', 'parentId', 'name', 'grade', 'classRoom'],
                      ['id', 'parentId', 'name', 'grade', 'classRoom', 'avatar', 
                       'teacherName', 'teacherEmail', 'dob', 'gradesValidated', 
                       'attendanceValidated']) &&
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data) &&
                    request.resource.data.name is string &&
                    request.resource.data.name.size() < 100 &&
                    request.resource.data.grade is string &&
                    request.resource.data.grade.size() < 50;
      
      allow update: if isSignedIn() && resource != null &&
                    (isSuperAdmin() || isOwnerOrDemoWrite(resource.data.parentId)) &&
                    (isSuperAdmin() || isOwnerOrDemoWrite(request.resource.data.parentId)) &&
                    (isSuperAdmin() || isImmutable('parentId')) &&
                    validateFields(request.resource.data,
                      [],
                      ['id', 'parentId', 'name', 'grade', 'classRoom', 'avatar', 
                       'teacherName', 'teacherEmail', 'dob', 'gradesValidated', 
                       'attendanceValidated']) &&
                    !('role' in request.resource.data) && 
                    !('isAdmin' in request.resource.data) &&
                    request.resource.data.name is string &&
                    request.resource.data.name.size() < 100;
      
      allow delete: if isSignedIn() && resource != null &&
                    (isSuperAdmin() || isOwnerOrDemoWrite(resource.data.parentId));
    }

    // ==========================================
    // 6. NOTES (GRADES)
    // ==========================================
    match /grades/{gradeId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(gradeId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    isValidNumber(request.resource.data.score) &&
                    isValidNumber(request.resource.data.maxScore) &&
                    request.resource.data.score >= 0 && 
                    request.resource.data.maxScore >= 0 &&
                    request.resource.data.score <= request.resource.data.maxScore &&
                    validateFields(request.resource.data,
                      ['id', 'studentId', 'parentId', 'subject', 'score', 'maxScore'],
                      ['id', 'studentId', 'parentId', 'subject', 'examName', 
                       'score', 'maxScore', 'teacherRemarks', 'date']) &&
                    request.resource.data.subject is string &&
                    request.resource.data.subject.size() < 100;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) &&
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    isImmutable('parentId') && 
                    isImmutable('studentId') &&
                    isValidNumber(request.resource.data.score) &&
                    isValidNumber(request.resource.data.maxScore) &&
                    request.resource.data.score >= 0 && 
                    request.resource.data.maxScore >= 0 &&
                    request.resource.data.score <= request.resource.data.maxScore &&
                    validateFields(request.resource.data,
                      [],
                      ['id', 'studentId', 'parentId', 'subject', 'examName', 
                       'score', 'maxScore', 'teacherRemarks', 'date']);
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 7. PRÉSENCE (ATTENDANCE)
    // ==========================================
    match /attendance/{attendanceId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(attendanceId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    validateFields(request.resource.data,
                      ['id', 'studentId', 'parentId', 'date', 'status'],
                      ['id', 'studentId', 'parentId', 'date', 'status', 'remarks']) &&
                    request.resource.data.status in ['Present', 'Absent', 'Late', 'Excused'] &&
                    request.resource.data.date is timestamp;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') &&
                    validateFields(request.resource.data,
                      [],
                      ['id', 'studentId', 'parentId', 'date', 'status', 'remarks']) &&
                    request.resource.data.status in ['Present', 'Absent', 'Late', 'Excused'];
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 8. DEVOIRS (HOMEWORKS)
    // ==========================================
    match /homeworks/{homeworkId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(homeworkId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    validateFields(request.resource.data,
                      ['id', 'studentId', 'parentId', 'subject', 'title', 'dueDate'],
                      ['id', 'studentId', 'parentId', 'subject', 'title', 
                       'description', 'dueDate', 'status', 'grade']) &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() < 200 &&
                    request.resource.data.description is string &&
                    request.resource.data.description.size() < 2000 &&
                    request.resource.data.dueDate is timestamp;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') &&
                    validateFields(request.resource.data,
                      [],
                      ['id', 'studentId', 'parentId', 'subject', 'title', 
                       'description', 'dueDate', 'status', 'grade']) &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() < 200;
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 9. RENDEZ-VOUS (APPOINTMENTS)
    // ==========================================
    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(appointmentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    validateFields(request.resource.data,
                      ['id', 'studentId', 'parentId', 'teacherName', 'subject', 'dateTime'],
                      ['id', 'studentId', 'parentId', 'teacherName', 'subject', 
                       'dateTime', 'status', 'notes']) &&
                    request.resource.data.dateTime is timestamp &&
                    request.resource.data.teacherName is string &&
                    request.resource.data.teacherName.size() < 100;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') && 
                    resource.data.status != 'Cancelled' &&
                    validateFields(request.resource.data,
                      [],
                      ['id', 'studentId', 'parentId', 'teacherName', 'subject', 
                       'dateTime', 'status', 'notes']) &&
                    request.resource.data.status in ['Scheduled', 'Completed', 'Cancelled'];
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 10. MESSAGES
    // ==========================================
    match /messages/{messageId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(messageId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() < 5000 && 
                    validateFields(request.resource.data,
                      ['id', 'studentId', 'parentId', 'senderType', 'content', 'timestamp'],
                      ['id', 'studentId', 'parentId', 'senderType', 'content', 
                       'timestamp', 'teacherName']) &&
                    request.resource.data.senderType in ['parent', 'teacher', 'admin'];
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    isImmutable('studentId') &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() < 5000 && 
                    validateFields(request.resource.data,
                      [],
                      ['id', 'studentId', 'parentId', 'senderType', 'content', 
                       'timestamp', 'teacherName']);
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 11. FACTURES (INVOICES)
    // ==========================================
    match /invoices/{invoiceId} {
      allow get: if isSignedIn() && resource != null &&
                 (isSuperAdmin() || isOwnerOrDemoRead(resource.data.parentId) || 
                  invoiceId.matches('^log_.*'));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || isOwnerOrDemoList(request.query.parentId));
      
      allow create: if isSignedIn() && isSafeId(invoiceId) && (
                      (invoiceId.matches('^log_.*')) ||
                      (
                        (isSuperAdmin() || isOwnerOrDemoWrite(request.resource.data.parentId)) && 
                        isValidNumber(request.resource.data.amount) &&
                        request.resource.data.amount >= 0 && 
                        (!('amountPaid' in request.resource.data) || 
                         (isValidNumber(request.resource.data.amountPaid) &&
                          request.resource.data.amountPaid >= 0))
                      )
                    );
      
      allow update: if isSignedIn() && resource != null && isSafeId(invoiceId) && (
                      (invoiceId.matches('^log_.*')) ||
                      (
                        (isSuperAdmin() || isOwnerOrDemoWrite(resource.data.parentId)) && 
                        (isSuperAdmin() || isOwnerOrDemoWrite(request.resource.data.parentId)) && 
                        (isSuperAdmin() || isDemoId(resource.data.parentId) || isImmutable('parentId')) && 
                        (isSuperAdmin() || isDemoId(resource.data.parentId) || isImmutable('studentId')) && 
                        isValidNumber(request.resource.data.amount) &&
                        request.resource.data.amount >= 0 && 
                        (!('amountPaid' in request.resource.data) || 
                         (isValidNumber(request.resource.data.amountPaid) &&
                          request.resource.data.amountPaid >= 0))
                      )
                    );
      
      allow delete: if isSignedIn() && resource != null &&
                    (invoiceId.matches('^log_.*') || 
                     isOwnerOrDemoWrite(resource.data.parentId) || 
                     isSuperAdmin());
    }

    // ==========================================
    // 12. JOURNAUX DE LECTURE (READING LOGS)
    // ==========================================
    match /reading_logs/{logId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isSafeId(logId) && 
                    isOwnerOrDemoWrite(getStudent(request.resource.data.studentId).parentId) && 
                    validateFields(request.resource.data,
                      ['studentId', 'studentName', 'bookTitle', 'status'],
                      ['studentId', 'studentName', 'bookTitle', 'bookAuthor', 
                       'genre', 'status', 'progressPercent', 'parentNotes', 
                       'rating', 'addedAt']) &&
                    request.resource.data.bookTitle is string &&
                    request.resource.data.bookTitle.size() < 200 &&
                    request.resource.data.progressPercent is int &&
                    request.resource.data.progressPercent >= 0 &&
                    request.resource.data.progressPercent <= 100;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(getStudent(resource.data.studentId).parentId) &&
                    isOwnerOrDemoWrite(getStudent(request.resource.data.studentId).parentId) && 
                    isImmutable('studentId') && 
                    validateFields(request.resource.data,
                      [],
                      ['studentId', 'studentName', 'bookTitle', 'bookAuthor', 
                       'genre', 'status', 'progressPercent', 'parentNotes', 
                       'rating', 'addedAt']) &&
                    request.resource.data.progressPercent is int &&
                    request.resource.data.progressPercent >= 0 &&
                    request.resource.data.progressPercent <= 100;
      
      allow delete: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(getStudent(resource.data.studentId).parentId);
    }

    // ==========================================
    // 13. ANNONCES (ANNOUNCEMENTS)
    // ==========================================
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isSafeId(announcementId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    validateFields(request.resource.data,
                      ['id', 'title', 'content', 'date', 'parentId'],
                      ['id', 'title', 'content', 'category', 'date', 'author', 'parentId']) &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() < 200 &&
                    request.resource.data.content is string &&
                    request.resource.data.content.size() < 5000 &&
                    request.resource.data.date is timestamp;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') && 
                    validateFields(request.resource.data,
                      [],
                      ['id', 'title', 'content', 'category', 'date', 'author', 'parentId']) &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() < 200;
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 14. LEÇONS (LESSONS)
    // ==========================================
    match /lessons/{lessonId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && isSafeId(lessonId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) &&
                    request.resource.data.size() < 10000;
      
      allow update: if isSignedIn() && resource != null &&
                    isOwnerOrDemoWrite(resource.data.parentId) && 
                    isOwnerOrDemoWrite(request.resource.data.parentId) && 
                    isImmutable('parentId') &&
                    request.resource.data.size() < 10000;
      
      allow delete: if isSignedIn() && resource != null &&
                    (isOwnerOrDemoWrite(resource.data.parentId) || isSuperAdmin());
    }

    // ==========================================
    // 15. SUPER ADMINISTRATEURS
    // ==========================================
    match /super_admins/{adminId} {
      allow get: if isSignedIn() && 
                 (isSuperAdmin() || 
                  ('email' in request.auth.token && 
                   request.auth.token.email.lower() == adminId.lower()));
      
      allow list: if isSignedIn() && 
                 (isSuperAdmin() || 
                  ('email' in request.auth.token && 
                   exists(/databases/$(database)/documents/super_admins/$(request.auth.token.email.lower()))));
      
      allow write: if isSignedIn() && isSuperAdmin();
    }

    // ==========================================
    // 16. SESSIONS ACTIVES - SÉCURISÉES
    // ==========================================
    match /active_sessions/{sessionId} {
      allow read: if isSignedIn() && request.auth.uid == sessionId;
      
      allow create: if isSignedIn() && 
                    request.auth.uid == sessionId &&
                    request.resource.data.uid == request.auth.uid &&
                    request.resource.data.size() < 5000;
      
      allow update: if isSignedIn() && 
                    request.auth.uid == sessionId &&
                    request.resource.data.uid == request.auth.uid &&
                    isImmutable('uid') &&
                    request.resource.data.size() < 5000;
      
      allow delete: if isSignedIn() && 
                    request.auth.uid == sessionId;
    }

  }
}
