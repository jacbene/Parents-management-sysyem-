rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'jacquesbene301@gmail.com' ||
        request.auth.uid == 'sys_admin_jacques' ||
        (request.auth.token.email != null && request.auth.token.email.matches('.*@pasma\\.sys'))
      );
    }

    function isOwner(parentId) {
      return isSignedIn() && (parentId == request.auth.uid || isSuperAdmin());
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isSchoolManagerOrDemo(schoolId) {
      return isSuperAdmin() || (isSignedIn() && schoolId is string && (
        schoolId.matches('^demo_school.*') ||
        schoolId == request.auth.uid ||
        schoolId.matches('^sch_.*') ||
        exists(/databases/$(database)/documents/establishments/$(schoolId))
      ));
    }

    function canViewData(parentId) {
      return isSuperAdmin() || (isSignedIn() && parentId is string && (
        parentId == request.auth.uid ||
        parentId.matches('^demo_school.*') ||
        parentId.matches('^sch_.*') ||
        exists(/databases/$(database)/documents/establishments/$(parentId))
      ));
    }

    // Entity validator functions
    function isValidStudent(data) {
      return data.id is string && data.id.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.grade is string && data.grade.size() <= 50
          && data.classRoom is string && data.classRoom.size() <= 50
          && data.avatar is string && data.avatar.size() <= 1000000;
    }

    function isValidGrade(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.subject is string && data.subject.size() <= 100
          && data.examName is string && data.examName.size() <= 100
          && data.score is number && data.score >= 0 && data.score <= 1000
          && data.maxScore is number && data.maxScore > 0
          && data.get('teacherRemarks', '') is string && data.get('teacherRemarks', '').size() <= 1000
          && data.date is string;
    }

    function isValidAttendance(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.date is string
          && data.status is string && (data.status == 'Present' || data.status == 'Absent' || data.status == 'Late' || data.status == 'Excused')
          && data.get('remarks', '') is string && data.get('remarks', '').size() <= 1000;
    }

    function isValidHomework(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.subject is string && data.subject.size() <= 100
          && data.title is string && data.title.size() <= 200
          && data.get('description', '') is string && data.get('description', '').size() <= 2000
          && data.dueDate is string
          && data.status is string && (data.status == 'Pending' || data.status == 'Completed' || data.status == 'Overdue')
          && data.get('grade', '') is string && data.get('grade', '').size() <= 50;
    }

    function isValidAnnouncement(data) {
      return data.id is string && data.id.size() <= 128
          && data.title is string && data.title.size() <= 200
          && data.content is string && data.content.size() <= 5000
          && data.category is string && (data.category == 'General' || data.category == 'Academic' || data.category == 'Event' || data.category == 'Urgent')
          && data.date is string
          && data.get('parentId', '') is string
          && data.get('author', '') is string && data.get('author', '').size() <= 100;
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.teacherName is string && data.teacherName.size() <= 100
          && data.subject is string && data.subject.size() <= 100
          && data.dateTime is string
          && data.status is string && (data.status == 'Scheduled' || data.status == 'Completed' || data.status == 'Cancelled')
          && data.get('notes', '') is string && data.get('notes', '').size() <= 1000;
    }

    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.senderType is string && (data.senderType == 'Parent' || data.senderType == 'Teacher')
          && data.content is string && data.content.size() <= 2000
          && data.timestamp is string
          && data.get('teacherName', '') is string && data.get('teacherName', '').size() <= 100;
    }

    function isValidInvoice(data) {
      return data.id is string && data.id.size() <= 128
          && data.studentId is string && data.studentId.size() <= 128
          && data.parentId is string && (data.parentId == request.auth.uid || isSchoolManagerOrDemo(data.parentId))
          && data.title is string && data.title.size() <= 200
          && data.amount is number
          && data.dueDate is string
          && data.status is string && (data.status == 'Paid' || data.status == 'Unpaid' || data.status == 'Overdue')
          && data.get('paymentDate', '') is string && data.get('paymentDate', '').size() <= 100
          && data.get('transactionId', '') is string && data.get('transactionId', '').size() <= 200
          && data.get('provider', '') is string && data.get('provider', '').size() <= 100;
    }

    function isValidEstablishment(data) {
      return data.id is string
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.cotisationAmount is number
          && data.ownerId is string && (data.ownerId == request.auth.uid || data.ownerId == 'demo_admin');
    }

    // --- Establishments Collection ---
    match /establishments/{establishmentId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isValidId(establishmentId) && isValidEstablishment(incoming());
      allow update, delete: if isSignedIn() && (isSuperAdmin() || resource.data.ownerId == request.auth.uid || establishmentId.matches('^demo_school.*'));
    }

    // --- Students Collection ---
    match /students/{studentId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(studentId) && isValidStudent(incoming());
      allow update: if isSignedIn() && isValidStudent(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Grades Collection ---
    match /grades/{gradeId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(gradeId) && isValidGrade(incoming());
      allow update: if isSignedIn() && isValidGrade(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Attendance Collection ---
    match /attendance/{attendanceId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(attendanceId) && isValidAttendance(incoming());
      allow update: if isSignedIn() && isValidAttendance(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Homeworks Collection ---
    match /homeworks/{homeworkId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(homeworkId) && isValidHomework(incoming());
      allow update: if isSignedIn() && isValidHomework(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Announcements Collection ---
    match /announcements/{announcementId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(announcementId) && isValidAnnouncement(incoming()) && (isOwner(incoming().parentId) || isSchoolManagerOrDemo(incoming().parentId));
      allow update: if isSignedIn() && isValidAnnouncement(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Appointments Collection ---
    match /appointments/{appointmentId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(appointmentId) && isValidAppointment(incoming());
      allow update: if isSignedIn() && isValidAppointment(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Messages Collection ---
    match /messages/{messageId} {
      allow get, list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming());
      allow update: if isSignedIn() && isValidMessage(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
      allow delete: if isSignedIn() && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId));
    }

    // --- Invoices Collection ---
    match /invoices/{invoiceId} {
      allow get: if isSignedIn() || invoiceId.matches('^demo_school.*') || invoiceId.matches('^sch_.*') || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow list: if isSignedIn() || (resource != null && (resource.data.parentId.matches('^demo_school.*') || resource.data.parentId.matches('^sch_.*')));
      allow create: if isSignedIn() || invoiceId.matches('^demo_school.*') || invoiceId.matches('^sch_.*') || isSuperAdmin() || (isValidId(invoiceId) && isValidInvoice(incoming()));
      allow update: if isSignedIn() || invoiceId.matches('^demo_school.*') || invoiceId.matches('^sch_.*') || isSuperAdmin() || (isValidInvoice(incoming()) && (isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId)));
      allow delete: if isSignedIn() || invoiceId.matches('^demo_school.*') || invoiceId.matches('^sch_.*') || isSuperAdmin() || isOwner(resource.data.parentId) || isSchoolManagerOrDemo(resource.data.parentId);
    }

    // --- Reading Logs Collection ---
    match /reading_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    // --- Super Admins Collection ---
    match /super_admins/{adminId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (
        request.auth.token.email == 'jacquesbene301@gmail.com' ||
        request.auth.uid == 'sys_admin_jacques'
      );
    }
  }
}
